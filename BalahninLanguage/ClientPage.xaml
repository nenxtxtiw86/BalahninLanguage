<Page x:Class="BalahninLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BalahninLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="ClientPage" FontFamily="Comic Sans MS" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="85"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Rectangle Grid.Row="0" Grid.ColumnSpan="2" Fill="#FFE6FABF"/>
        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1">
            <TextBlock Text="Поиск: " FontSize="20"></TextBlock>
            <TextBox Name="TBox_Search" Height="30"  TextChanged="TBox_Search_TextChanged" Width="300" />
        </WrapPanel>
        <ListView Name="ListViewClient" Grid.ColumnSpan="3" Grid.Row="2"  d:ItemsSource="{d:SampleData ItemCount=5}" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Image Width="200"  Grid.Column="0" Stretch="Fill" HorizontalAlignment="Center" Grid.RowSpan="10">
                            <Image.Source>
                                <Binding Path="PhotoPath">
                                </Binding>
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                            <TextBlock  Text="{Binding ID}" FontSize="20" ></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding LastName}" FontSize="20"></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding FirstName}"  FontSize="20"></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding Patronymic}"  FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Пол: " FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding GenderCode}" Grid.Column="1" Grid.Row="1" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="Дата рождения: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}" Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                            <TextBlock Text="Телефон: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding Phone}" Grid.Column="1" Grid.Row="3" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="4" Orientation="Horizontal">
                            <TextBlock  Text="{Binding Email, StringFormat='Email: {0}'}" Grid.Column="1" Grid.Row="4" FontSize="20"></TextBlock>
                        </StackPanel>
                        <TextBlock  Text="{Binding RegistrationDate, StringFormat='Дата регистрации: {0:dd.MM.yyyy}'}" Grid.Column="1" Grid.Row="5" FontSize="20"></TextBlock>
                        <StackPanel Grid.Column="1" Grid.Row="6" Orientation="Horizontal">
                            <TextBlock Text="Дата последнего посещения: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding LastVisit}" Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="7" Orientation="Horizontal">
                            <TextBlock Text="Количество посещений: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding VisitCount}" Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                        </StackPanel>
                        <Button Name="EditClient" Content="Редактировать" Grid.Column="2" Grid.Row="3" Background="#FF03A0FA"  Margin="0,12,0,15" Grid.RowSpan="2" Click="EditClient_Click"></Button>
                        <Button Name="DeleteClient" Content="Удалить" Grid.Column="3" Grid.Row="2" Background="#FF03A0FA" Click="DeleteClient_Click"></Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2" RenderTransformOrigin="0.517,0.5" Width="258" >

        </WrapPanel>
        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" >
            <TextBlock Text="Пол: " FontSize="20"></TextBlock>
            <ComboBox Name="ComboGender"  Width="100" Height="30" SelectionChanged="ComboGender_SelectionChanged"  >
                <TextBlock>Все</TextBlock>
                <TextBlock>женский</TextBlock>
                <TextBlock>мужской</TextBlock>
            </ComboBox>

            <TextBlock Text="  Сортировка: " FontSize="20"></TextBlock>
            <ComboBox Name="ComboSort"  Width="198" Height="30" SelectionChanged="ComboSort_SelectionChanged" >
                <TextBlock>Нет</TextBlock>
                <TextBlock>От А до Я</TextBlock>
                <TextBlock>Дата последнего посещения</TextBlock>
                <TextBlock>Количество посещений</TextBlock>
            </ComboBox>
            <TextBlock Text="  "></TextBlock>
            <Button Name="BtnAdd" Content="Добавить клиента" Background="#FF03A0FA" Width="170" Click="BtnAdd_Click" Margin="5" Height="25"></Button>

        </WrapPanel>

        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Name="TBCount" FontSize="15" Height="30" ></TextBlock>
            <TextBlock Name="TBAllRecords" FontSize="15" Height="30" ></TextBlock>
            <TextBlock Text="  "></TextBlock>
            <TextBlock Text="Выводить по " FontSize="15" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"  ></TextBlock>
            <ComboBox Name="ComboPage" Width="100" Height="30" SelectionChanged="ComboPage_SelectionChanged" Grid.Row="3"  Grid.Column="1"  HorizontalAlignment="Right" />
            <Button Name="LeftDirButton" Content="&lt;" Width="25" Height="25" Click="LeftDirButton_Click" Background="#FF03A0FA"/>
            <ListBox FontSize="20" Name="PageListBox" MouseUp="PageListBox_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Width="25" Height="25" Click="RightDirButton_Click" Background="#FF03A0FA"/>
        </StackPanel>
    </Grid>
</Page>
