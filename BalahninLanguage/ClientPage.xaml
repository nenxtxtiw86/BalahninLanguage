<Page x:Class="BalahninLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BalahninLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="1000"
      Title="ClientPage" FontFamily="Comic Sans MS" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="85"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ListView Name="ListViewClient" Grid.ColumnSpan="3" Grid.Row="1"  d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Image Width="200"  Grid.RowSpan="10" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="PhotoPath">
                                </Binding>
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                            <TextBlock  Text="{Binding ID}" FontSize="20" ></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding FirstName}" FontSize="20"></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding LastName}"  FontSize="20"></TextBlock>
                            <TextBlock  Text="  " FontSize="20" ></TextBlock>
                            <TextBlock  Text="{Binding Patronymic}"  FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Пол: " FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding GenderCode}" Grid.Column="1" Grid.Row="1" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="Дата рождения: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}" Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                            <TextBlock Text="Телефон: " Grid.Column="1" Grid.Row="2" FontSize="20"></TextBlock>
                            <TextBlock  Text="{Binding Phone}" Grid.Column="1" Grid.Row="3" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="4" Orientation="Horizontal">
                            <TextBlock  Text="{Binding Email, StringFormat='Email: {0}'}" Grid.Column="1" Grid.Row="4" FontSize="20"></TextBlock>
                        </StackPanel>
                        <TextBlock  Text="{Binding RegistrationDate, StringFormat='Дата регистрации: {0:dd.MM.yyyy}'}" Grid.Column="1" Grid.Row="5" FontSize="20"></TextBlock>
                        <Button Name="DeleteClient" Content="Удалить" Grid.Column="3" Grid.Row="2" Background="#FF03A0FA" Click="DeleteClient_Click"></Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ComboBox Name="ComboGender" Grid.Column="2" Grid.Row="0" Width="100" Height="30" SelectionChanged="ComboGender_SelectionChanged" Margin="34,28,133,27"  >
            <TextBlock>Все</TextBlock>
            <TextBlock>ж</TextBlock>
            <TextBlock>м</TextBlock>
        </ComboBox>
        <ComboBox Name="ComboSort" Grid.Column="2" Grid.Row="0" Width="100" Height="30" SelectionChanged="ComboSort_SelectionChanged" Margin="149,28,18,27">
            <TextBlock>...</TextBlock>
            <TextBlock>От А до Я</TextBlock>
            <TextBlock>Дата последнего посещения</TextBlock>
            <TextBlock>Количество посещений</TextBlock>
        </ComboBox>
        <Label x:Name="CurrentPageLabel" 
           Content="Страница: 1 из 1" 
           VerticalAlignment="Center" 
           Margin="40,0,10,0"
           FontSize="12"
           FontWeight="Bold" Grid.Row="2"/>
        <TextBlock Text="Выводить по " FontSize="15" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="127,0,333,0" ></TextBlock>
        <ComboBox Name="ComboPage" Width="100" Height="30" SelectionChanged="ComboPage_SelectionChanged" Grid.Row="3"  Grid.Column="1"  HorizontalAlignment="Right" />
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="LeftDirButton" Content="&lt;" Width="25" Height="25" Click="LeftDirButton_Click" Background="#FF03A0FA"/>
            <ListBox FontSize="20" Name="PageListBox" MouseUp="PageListBox_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Width="25" Height="25" Click="RightDirButton_Click" Background="#FF03A0FA"/>
        </StackPanel>
    </Grid>
</Page>
