<Page x:Class="BalahninLanguage.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BalahninLanguage"
            xmlns:sys="clr-namespace:System;assembly=mscorlib"

      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1200"
      Title="AddEditPage" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70 "/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="41*"/>
            <ColumnDefinition Width="134*"/>
            <ColumnDefinition Width="125*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="ID" FontSize="20" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Visibility="Collapsed" Name="LblID"></TextBlock>
        <TextBlock Text="Фамилия" FontSize="20" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" ></TextBlock>
        <TextBlock Text="Имя" FontSize="20" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Text="Отчество" FontSize="20" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Text="Email" FontSize="20" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Text="Телефон" FontSize="20" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Text="Дата рождения" FontSize="20" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Text="Пол" FontSize="20" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"></TextBlock>
        <TextBox Grid.Row="1" Grid.Column="1" Width="300" Height="40" Text="{Binding ID}" Visibility="Collapsed" IsReadOnly="True" Background="LightGray" Name="TxtID" ></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Width="300" Height="40" Text="{Binding LastName}" ></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Width="300" Height="40" Text="{Binding FirstName}" ></TextBox>
        <TextBox Grid.Row="4" Grid.Column="1" Width="300" Height="40" Text="{Binding Patronymic}" ></TextBox>
        <TextBox Grid.Row="5" Grid.Column="1" Width="300" Height="40" Text="{Binding Email}" ></TextBox>
        <TextBox Grid.Row="6" Grid.Column="1" Width="300" Height="40" Text="{Binding Phone}" ></TextBox>
        <DatePicker Grid.Row="7" Grid.Column="1" Width="300" Height="40" FontSize="20" Name="DateBirthday" SelectedDate="{x:Static sys:DateTime.Now}"></DatePicker>
        <StackPanel Grid.Row="8" Grid.Column="1" Width="200" HorizontalAlignment="Left" Margin="10">
            <RadioButton  Content="Женский" Checked="RadioButton_RButtonWoman" Name="RButtonWoman" FontSize="20" GroupName="Gender" ></RadioButton>
            <RadioButton  Content="Мужской" Checked="RadioButton_RButtonMens" Name="RButtonMens" FontSize="20" GroupName="Gender" ></RadioButton>
        </StackPanel>
        <Button Content="Сохранить" Grid.Row="8" Height="35" Width="200" HorizontalAlignment="Right" Grid.Column="1" Margin="0,29,420,6" Background="#FF03A0FA" FontSize="20" Click="SaveButton_Click" Grid.ColumnSpan="2"/>
        <StackPanel  Grid.Row="2" Grid.RowSpan="3" Grid.Column="2" Orientation="Vertical" >
            <TextBlock Text="Фото" FontSize="20" Width="334" ></TextBlock>
            <Image x:Name="LogoImage" Width="200" Height="100"/>
            <Button Content="Изменить" Name="ChaghePictureBtn" Click="ChangePictureBtn_Click" Width="250" Height="25" Background="#FF03A0FA"></Button>
        </StackPanel>
    </Grid>
</Page>
