<Window x:Class="BalahninLanguage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BalahninLanguage"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1200"  FontFamily="Comic Sans MS">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="197*"/>
            <ColumnDefinition Width="403*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="85"></RowDefinition>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>
        <Rectangle Grid.Row="0" Grid.ColumnSpan="2" Fill="#FFE6FABF"/>

        <Frame Name="MainFrame" Grid.ColumnSpan="2" Grid.RowSpan="2" ContentRendered="MainFrame_ContentRendered" NavigationUIVisibility="Hidden"/>
        <TextBlock Name="LAUNGE" Text="Лангуаге" Grid.Row="0" HorizontalAlignment="Left" Margin="163,20,0,19" FontSize="20" Grid.Column="1" ></TextBlock>
        <Image Source="/res/school_logo.ico"  HorizontalAlignment="Left" Grid.Row="0"/>
        <Button Name="BtnBack" Content="Назад" Height="50" Width="100" HorizontalAlignment="Right"  Click="BtnBackClick" Visibility="Hidden" Grid.Column="1" Margin="10" Background="#FF03A0FA"></Button>
    </Grid>
</Window>
